# DB 운영 스크립트용 접속 정보. 이 파일을 scripts/.env 로 복사해서 값을 채운다.
# scripts/.env 는 .gitignore 됨. 커맨드라인 inline env(SRC_PASSWORD=*** node ...)가 항상 우선.

# 소스(보통 SSH 터널로 연결된 라이브) — clone-live-db.js
SRC_HOST=127.0.0.1
SRC_PORT=3307
SRC_USER=root
SRC_PASSWORD=
SRC_DATABASE=zeroboom_bot

# 대상(테섭 등) — import-to-test-db.js
DEST_HOST=127.0.0.1
DEST_PORT=3307
DEST_USER=root
DEST_PASSWORD=
DEST_DATABASE=zeroboom_bot_test
